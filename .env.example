# Server
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Anthropic Realtime upstream (key MUST start with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-api03-your-real-key
ANTHROPIC_REALTIME_WSS_URL=wss://api.anthropic.com/v1/realtime
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_VERSION=2023-06-01

# Audio pipeline (16-bit PCM @ 24 kHz mono, or Opus packets)
AUDIO_FORMAT=pcm16
SAMPLE_RATE=24000
CHUNK_DURATION_MS=40
RING_BUFFER_SECONDS=10

# Spectral-entropy VAD (hangover preserves trailing consonants / pauses)
VAD_ENTROPY_THRESHOLD=7.5
VAD_ENERGY_FLOOR=0.0015
VAD_FRICATIVE_RATIO=0.18
VAD_HANGOVER_MS=400

# Backpressure / circuit breaking
HIGH_WATER_MARK=262144
MAX_BUFFERED_BYTES=1048576
RATE_LIMIT_BASE_DELAY_MS=500
RATE_LIMIT_MAX_DELAY_MS=30000
