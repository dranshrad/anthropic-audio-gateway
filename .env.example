# Server
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Provider: anthropic | openai | gemini | deepgram | mock
PROVIDER=mock
METRICS_ENABLED=true
ADAPTIVE_STREAMING=true
VAD_ENGINE=spectral-entropy
WEBRTC_INGRESS=true

# Anthropic (required when PROVIDER=anthropic; must start with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-api03-your-real-key
ANTHROPIC_REALTIME_WSS_URL=wss://api.anthropic.com/v1/realtime
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_API_VERSION=2023-06-01

# OpenAI (when PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_REALTIME_WSS_URL=wss://api.openai.com/v1/realtime?model=gpt-4o-realtime-preview
OPENAI_MODEL=gpt-4o-realtime-preview

# Gemini (when PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_REALTIME_WSS_URL=wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1alpha.GenerativeService.BidiGenerateContent
GEMINI_MODEL=gemini-2.0-flash-live

# Deepgram (when PROVIDER=deepgram)
DEEPGRAM_API_KEY=
DEEPGRAM_REALTIME_WSS_URL=wss://api.deepgram.com/v1/listen
DEEPGRAM_MODEL=nova-2

# Audio pipeline
AUDIO_FORMAT=pcm16
SAMPLE_RATE=24000
CHUNK_DURATION_MS=40
RING_BUFFER_SECONDS=10

# Spectral-entropy VAD
VAD_ENTROPY_THRESHOLD=7.5
VAD_ENERGY_FLOOR=0.0015
VAD_FRICATIVE_RATIO=0.18
VAD_HANGOVER_MS=400

# Backpressure
HIGH_WATER_MARK=262144
MAX_BUFFERED_BYTES=1048576
RATE_LIMIT_BASE_DELAY_MS=500
RATE_LIMIT_MAX_DELAY_MS=30000

# Auth — empty AUTH_JWT_SECRET = OPEN RELAY (any client can use your API key).
# Set AUTH_JWT_SECRET before exposing beyond localhost. Production: AUTH_REQUIRED=true.
AUTH_JWT_SECRET=
AUTH_REQUIRED=false
AUTH_ALLOWED_ORIGINS=
AUTH_RATE_LIMIT_PER_MINUTE=120
AUTH_MAX_SESSIONS_PER_SUBJECT=5
