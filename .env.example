# Server
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Anthropic Realtime upstream
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_REALTIME_WSS_URL=wss://api.anthropic.com/v1/realtime
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_VERSION=2023-06-01

# Audio pipeline (16-bit PCM @ 24 kHz mono, or Opus packets)
AUDIO_FORMAT=pcm16
SAMPLE_RATE=24000
CHUNK_DURATION_MS=40

# Voice Activity Detection (PCM energy threshold; 0 disables filtering)
VAD_ENERGY_THRESHOLD=0.01
VAD_HANGOVER_MS=300

# Backpressure: pause inbound client audio when upstream buffered bytes exceed this
MAX_BUFFERED_BYTES=1048576
RATE_LIMIT_BASE_DELAY_MS=500
RATE_LIMIT_MAX_DELAY_MS=30000
