{
	"name": "anthropic-audio-gateway",
	"version": "1.0.0",
	"description": "Production-grade WebSocket gateway that duplex-bridges browser audio streams to Anthropic's Realtime WSS API with VAD and backpressure.",
	"type": "module",
	"license": "AGPL-3.0-only",
	"engines": {
		"node": ">=20"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"keywords": ["anthropic", "websocket", "audio", "realtime", "gateway", "vad", "pcm", "opus"],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/example/anthropic-audio-gateway.git"
	},
	"bugs": {
		"url": "https://github.com/example/anthropic-audio-gateway/issues"
	},
	"homepage": "https://github.com/example/anthropic-audio-gateway#readme",
	"dependencies": {
		"ws": "^8.18.3",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.15.32",
		"@types/ws": "^8.18.1",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3"
	}
}
